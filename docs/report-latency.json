{
  "load": {
    "host": "https://staging.myapp.com",
    "users": 50,
    "spawn_rate": 10,
    "run_time": "60s"
  },
  "scenario": {
    "requests": [
      {"name": "List Users", "method": "GET", "path": "/api/users", "weight": 5},
      {"name": "Create Order", "method": "POST", "path": "/api/orders", "weight": 3},
      {"name": "Get Product", "method": "GET", "path": "/api/products/1", "weight": 4},
      {"name": "Health Check", "method": "GET", "path": "/health", "weight": 1},
      {"name": "Update Profile", "method": "PUT", "path": "/api/profile", "weight": 2}
    ]
  },
  "artifacts": {"storage": "docs/artifacts", "history": 30},
  "report": {
    "title": "Latency Deep Dive — Checkout Service",
    "preset": "latency",
    "theme": {
      "mode": "dark",
      "colors": {
        "primary": "#f472b6",
        "primary-light": "#fda4af",
        "bg": "#1a0a14",
        "card": "#2a1020",
        "text": "#fce7f3",
        "text-muted": "#d4a0b0",
        "line": "#3d1a2e",
        "pass-bg": "#064e3b",
        "warn-bg": "#78350f",
        "fail-bg": "#7f1d1d",
        "skip-bg": "#2d1525"
      }
    },
    "branding": {
      "name": "ShopFlow",
      "color": "#f472b6"
    },
    "charts": {
      "response_time": {
        "title": "Response Time Breakdown",
        "datasets": [
          {"key": "p50", "label": "Median", "color": "#86efac", "fill": true},
          {"key": "p95", "label": "P95", "color": "#f472b6"},
          {"key": "p99", "label": "P99", "color": "#fb923c", "dash": [5, 5]}
        ]
      }
    },
    "endpoint_table": {
      "columns": [
        {"key": "name", "label": "Endpoint"},
        {"key": "requests", "label": "Calls"},
        {"key": "avg", "label": "Avg ms", "highlight": {"warn": 100, "fail": 300}},
        {"key": "p50", "label": "P50 ms"},
        {"key": "p95", "label": "P95 ms", "highlight": {"warn": 200, "fail": 500}},
        {"key": "p99", "label": "P99 ms", "highlight": {"warn": 400, "fail": 800}},
        {"key": "max", "label": "Max ms", "highlight": {"fail": 1000}}
      ]
    }
  }
}
