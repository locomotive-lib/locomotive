{
  "load": {
    "host": "https://staging.myapp.com",
    "users": 50,
    "spawn_rate": 10,
    "run_time": "60s"
  },
  "scenario": {
    "requests": [
      {"name": "List Users", "method": "GET", "path": "/api/users", "weight": 5},
      {"name": "Create Order", "method": "POST", "path": "/api/orders", "weight": 3},
      {"name": "Get Product", "method": "GET", "path": "/api/products/1", "weight": 4},
      {"name": "Health Check", "method": "GET", "path": "/health", "weight": 1},
      {"name": "Update Profile", "method": "PUT", "path": "/api/profile", "weight": 2}
    ]
  },
  "artifacts": {"storage": "docs/artifacts", "history": 30},
  "report": {
    "title": "API Performance Report — Production v2.1",
    "theme": {
      "mode": "light",
      "colors": {
        "primary": "#059669",
        "primary-light": "#34d399"
      }
    },
    "branding": {
      "name": "Acme Corp",
      "color": "#059669"
    },
    "kpi": {
      "cards": [
        {"metric": "rps", "label": "Throughput", "format": "{value:.1f}", "unit": "req/s"},
        {"metric": "p95_ms", "label": "P95 Latency", "format": "{value:.0f}", "unit": "ms"},
        {"metric": "p99_ms", "label": "P99 Latency", "format": "{value:.0f}", "unit": "ms"},
        {"metric": "error_rate", "label": "SLA Errors", "format": "{value:.3f}", "unit": "%"},
        {"metric": "requests", "label": "Total Requests", "format": "{value:,}"},
        {"metric": "duration", "label": "Test Duration", "format": "duration"}
      ]
    },
    "charts": {
      "throughput": {
        "title": "Service Throughput",
        "datasets": [
          {"key": "rps", "label": "Requests/s", "color": "#059669", "y_axis": "left"},
          {"key": "users", "label": "Concurrent Users", "color": "#8b5cf6", "y_axis": "right", "fill": true}
        ]
      },
      "response_time": {
        "title": "Latency Distribution",
        "datasets": [
          {"key": "p50", "label": "P50", "color": "#059669"},
          {"key": "p95", "label": "P95", "color": "#f59e0b"},
          {"key": "p99", "label": "P99", "color": "#ef4444", "dash": [5, 5]}
        ]
      }
    }
  }
}
