{
  "load": {
    "host": "https://staging.myapp.com",
    "users": 50,
    "spawn_rate": 10,
    "run_time": "60s"
  },
  "scenario": {
    "requests": [
      {"name": "List Users", "method": "GET", "path": "/api/users", "weight": 5},
      {"name": "Create Order", "method": "POST", "path": "/api/orders", "weight": 3},
      {"name": "Get Product", "method": "GET", "path": "/api/products/1", "weight": 4},
      {"name": "Health Check", "method": "GET", "path": "/health", "weight": 1},
      {"name": "Update Profile", "method": "PUT", "path": "/api/profile", "weight": 2}
    ]
  },
  "artifacts": {"storage": "docs/artifacts", "history": 30},
  "report": {
    "title": "Infrastructure Capacity Report",
    "preset": "throughput",
    "theme": {
      "mode": "light",
      "colors": {
        "primary": "#0ea5e9",
        "primary-light": "#bae6fd",
        "bg": "#f0f9ff",
        "card": "#ffffff",
        "text": "#0c4a6e",
        "text-muted": "#7dd3fc",
        "line": "#bae6fd",
        "pass-bg": "#dcfce7",
        "pass": "#15803d",
        "warn-bg": "#fef9c3",
        "warn": "#a16207",
        "fail-bg": "#ffe4e6",
        "fail": "#be123c",
        "skip-bg": "#e0f2fe",
        "skip": "#0284c7"
      }
    },
    "branding": {
      "name": "CloudScale",
      "color": "#0ea5e9"
    },
    "charts": {
      "throughput": {
        "title": "Request Volume",
        "datasets": [
          {"key": "rps", "label": "Requests/s", "color": "#0ea5e9", "fill": true, "y_axis": "left"},
          {"key": "users", "label": "Active Users", "color": "#f97316", "y_axis": "right"}
        ]
      }
    },
    "endpoint_table": {
      "columns": [
        {"key": "name", "label": "Service"},
        {"key": "requests", "label": "Volume"},
        {"key": "rps", "label": "RPS"},
        {"key": "avg", "label": "Latency"},
        {"key": "error_rate", "label": "Errors", "highlight": {"warn": 0.5, "fail": 2}}
      ]
    }
  }
}
